{
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 0.0.0.0",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "design": "storybook dev -p 6006",
    "design:build": "storybook build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"**/*.{vue,css}\"",
    "lint:css:fix": "stylelint \"**/*.{vue,css}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm exec bddgen && pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec bddgen && pnpm exec playwright test --ui",
    "lighthouse": "unlighthouse-ci",
    "typecheck": "nuxi typecheck",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix",
    "*.{vue,css}": "stylelint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ],
    "overrides": {
      "serialize-javascript": "^7.0.3"
    }
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-links": "^10.2.15",
    "@storybook/vue3-vite": "^10.2.15",
    "@unlighthouse/cli": "^0.17.7",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.2",
    "happy-dom": "^20.8.3",
    "lint-staged": "^16.3.2",
    "nuxt": "^3.21.1",
    "playwright-bdd": "^8.4.2",
    "postcss-html": "^1.8.1",
    "postcss-nested": "^7.0.2",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.2.15",
    "stylelint": "^17.4.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.2.2",
    "idb-keyval": "^6.2.2",
    "radix-vue": "^1.9.17"
  }
}
